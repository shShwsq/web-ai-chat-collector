# ============================================================
# AI Chat 知识库 MCP Server 环境变量
# 使用方法：cp .env.example .env && 修改下面的值
# install.sh 会把 .env 复制到部署目录并供 systemd EnvironmentFile 读取
# ============================================================

# ---- DashScope（必填）----
# 用于查询时生成 embedding，须与扩展写入时同一模型
# 申请：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# embedding 模型，默认 text-embedding-v4（1024 维），不要改除非扩展也换模型
EMBEDDING_MODEL=text-embedding-v4

# ---- 向量库（必填，按你实际后端填一组）----
# 类型：chroma | milvus | pgvector | supabase | qdrant
VECTOR_STORE_TYPE=qdrant

# 服务地址（不含集合/表名）。各后端格式见下方注释
VECTOR_STORE_URL=http://localhost:6333

# API Key（Chroma 可空；Milvus/Qdrant 必填；pgvector/Supabase 填 PostgREST 的 anon key）
VECTOR_STORE_API_KEY=

# 集合/表名（须与扩展「远程向量库」配置里的一致）
VECTOR_STORE_COLLECTION=ai_chat_vectors

# ---- 后端地址格式参考（按你选的 VECTOR_STORE_TYPE 取一组，删除其余）----
# qdrant:    VECTOR_STORE_URL=http://localhost:6333
# chroma:    VECTOR_STORE_URL=http://localhost:8000
# milvus:    VECTOR_STORE_URL=https://<cluster-id>.server.gcp-us-west1.cloud.milvus.io
# pgvector:  VECTOR_STORE_URL=http://localhost:3000   (PostgREST 端口，不是 5432)
# supabase:  VECTOR_STORE_URL=https://<project-ref>.supabase.co

# ---- MCP 传输（生产部署用 sse；本地 stdio 调试则改成 stdio）----
MCP_TRANSPORT=sse

# sse 监听地址：固定 127.0.0.1，公网必须经 nginx 访问，不要改成 0.0.0.0
MCP_HOST=127.0.0.1

# sse 监听端口，nginx 会反代到这里
MCP_PORT=8765

# ---- nginx 公网配置（install.sh 用这些值生成 nginx 站点配置）----
# 对外域名（须先解析到本机 IP）
MCP_DOMAIN=mcp.your-domain.com

# 访问 token：留空则 install.sh 自动生成 32 字节随机 token
# 客户端调用时拼在 URL 里：https://<MCP_DOMAIN>/mcp?token=<MCP_TOKEN>
MCP_TOKEN=
